# ============================================================================
#  Cosmos Bot configuration. Copy to ".env" and fill in.
# ============================================================================

# --- Cosmos (the brain) -----------------------------------------------------
# Generate an API token at https://try-cosmos.com/settings (needs the Bot add-on or Gold).
COSMOS_API=https://try-cosmos.com
COSMOS_TOKEN=csk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Polymarket (your OWN keys - they live ONLY on your machine) ------------
# Your Polymarket wallet private key (export from your Polymarket account).
POLYMARKET_PRIVATE_KEY=
# For email/magic accounts use the proxy address as funder + signature type 1.
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1
CLOB_API_URL=https://clob.polymarket.com

# --- Safety -----------------------------------------------------------------
# DRY_RUN=true logs every trade it WOULD make without sending real orders.
# Set to false ONLY when you're ready to trade real money.
DRY_RUN=true

# --- What to trade (the filters) --------------------------------------------
MIN_INSIDER_SCORE=40       # only signals with insider score >= this
MIN_PRICE_CENTS=3          # skip dust / near-resolved
MAX_PRICE_CENTS=90         # skip "no edge left" entries
TRADE_USD=25               # dollars per trade
MAX_OPEN_TRADES_PER_DAY=30 # hard cap

# Categories: comma list to ALLOW (empty = all). e.g. "Sports,Crypto"
CATEGORIES_ALLOW=
# Categories to BLOCK (takes priority). e.g. "Politics"
CATEGORIES_BLOCK=

# --- Loop -------------------------------------------------------------------
POLL_SECONDS=120
